// Prisma 7 schema. Client is generated by the new `prisma-client` generator
// (TypeScript, ESM) into ../generated/prisma and consumed via the PrismaPg
// driver adapter in ../lib/prisma.ts. Server-side only — never import the
// generated client into browser/client components.

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  // Prisma 7: the connection URL lives in prisma.config.ts (datasource.url) for
  // Migrate/introspection, and is passed to PrismaClient via the PrismaPg
  // adapter at runtime — not here.
}

// Starter models — replace with your own
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  posts     Post[]
  createdAt DateTime @default(now())
}

model Post {
  id        Int      @id @default(autoincrement())
  title     String
  content   String?
  published Boolean  @default(false)
  author    User     @relation(fields: [authorId], references: [id])
  authorId  Int
  createdAt DateTime @default(now())
}
