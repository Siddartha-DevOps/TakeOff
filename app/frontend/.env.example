# Frontend build config. Copy to your host's env (Vercel → Project → Settings →
# Environment Variables). REQUIRED in production, else the app calls localhost
# and every API request (including login) fails to reach the backend.
#
# VITE_BACKEND_URL must be the HTTPS URL of the deployed FastAPI backend, e.g.
#   VITE_BACKEND_URL=https://api.yourdomain.com
VITE_BACKEND_URL=
