{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "npm --prefix app/frontend install",
  "buildCommand": "npm --prefix app/frontend run build",
  "outputDirectory": "app/frontend/dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://takeoff-api.onrender.com/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
